    {
      "parameters": {
        "jsCode": "const tarefas = $input.all();\n\nconst titulo = $('AI Agent').first().json.output.titulo;\n\nconst tarefa = tarefas.find(item =>\n    item.json.titulo.toLowerCase() === titulo.toLowerCase()\n);\n\nif (!tarefa) {\n    throw new Error(\"Tarefa não encontrada.\");\n}\n\nreturn [\n    {\n        json: {\n            id: tarefa.json.id,\n            titulo: tarefa.json.titulo\n        }\n    }\n];"
      },
